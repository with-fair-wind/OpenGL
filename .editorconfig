# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4

[{CMakeLists.txt,*.cmake}]
indent_size = 4

[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[.clang*]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.sh]
indent_size = 4

[*.{bat,cmd,ps1}]
end_of_line = crlf
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab
